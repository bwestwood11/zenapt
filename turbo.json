{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"],
      "env": [
        "ADMIN_JWT_SECRET",
        "ADMIN_SEED_PASSWORD",
        "AWS_ACCESS_KEY",
        "AWS_REGION",
        "AWS_SECRET",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "CAL_API_KEY",
        "CORS_ORIGINS",
        "CUSTOMER_JWT_SECRET",
        "DASHBOARD_URL",
        "DATABASE_URL",
        "DATABASE_URL_POOLER",
        "ENCRYPTION_KEY",
        "EVENT_TYPE_ID",
        "FROM_EMAIL",
        "INVITE_SECRET",
        "NEXT_PUBLIC_BASE_URL",
        "NEXT_PUBLIC_GOOGLE_MAPS_API_KEY",
        "NEXT_PUBLIC_SERVER_URL",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_SUPPORT_EMAIL",
        "NEXT_PUBLIC_UNLAYER_PROJECT_ID",
        "NODE_ENV",
        "PORT",
        "REDIS_URL",
        "RESEND_API_KEY",
        "S3_BUCKET_NAME",
        "SES_ACCESS_KEY",
        "SES_SECRET_KEY",
        "SIGNING_KEY",
        "STRIPE_CONNECT_WEBHOOK_SECRET",
        "STRIPE_PRICE_ID",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "TWILLIO_ACCOUNT_SID",
        "TWILLIO_AUTH_TOKEN",
        "VITE_IFRAME_BASE_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "env": [
        "ADMIN_JWT_SECRET",
        "ADMIN_SEED_PASSWORD",
        "AWS_ACCESS_KEY",
        "AWS_REGION",
        "AWS_SECRET",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "CAL_API_KEY",
        "CORS_ORIGINS",
        "CUSTOMER_JWT_SECRET",
        "DASHBOARD_URL",
        "DATABASE_URL",
        "DATABASE_URL_POOLER",
        "ENCRYPTION_KEY",
        "EVENT_TYPE_ID",
        "FROM_EMAIL",
        "INVITE_SECRET",
        "NEXT_PUBLIC_BASE_URL",
        "NEXT_PUBLIC_GOOGLE_MAPS_API_KEY",
        "NEXT_PUBLIC_SERVER_URL",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_SUPPORT_EMAIL",
        "NEXT_PUBLIC_UNLAYER_PROJECT_ID",
        "NODE_ENV",
        "PORT",
        "REDIS_URL",
        "RESEND_API_KEY",
        "S3_BUCKET_NAME",
        "SES_ACCESS_KEY",
        "SES_SECRET_KEY",
        "SIGNING_KEY",
        "STRIPE_CONNECT_WEBHOOK_SECRET",
        "STRIPE_PRICE_ID",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "TWILLIO_ACCOUNT_SID",
        "TWILLIO_AUTH_TOKEN",
        "VITE_IFRAME_BASE_URL"
      ],
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false,
      "persistent": true
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:reset": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false,
      "persistent": true
    }
  }
}
